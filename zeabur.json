{
  "$schema": "https://schema.zeabur.app/template.json",
  "build": {
    "type": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "ports": [8080],
  "healthCheck": {
    "path": "/",
    "port": 8080
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "CONFIG_DIR": "/data"
  },
  "volumes": [
    {
      "id": "data",
      "dir": "/data"
    }
  ]
}
